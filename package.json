{
  "name": "safeclaw",
  "version": "0.1.0",
  "description": "Sandboxed Docker container running Claude Code",
  "scripts": {
    "build": "./scripts/build.sh",
    "start:claude": "./scripts/run.sh -a claude",
    "start:cursor": "./scripts/run.sh -a cursor",
    "list": "docker ps --filter name=safeclaw*",
    "stop-all": "docker stop $(docker ps -aq --filter \"name=safeclaw*\")",
    "kill-all": "docker rm $(docker ps -aq --filter \"name=safeclaw*\")",
    "purge": "npm run stop-all && npm run kill-all",
    "mount": "./scripts/run.sh -v",
    "setup-gemini": "./scripts/setup-gemini.sh",
    "setup-slack": "./scripts/setup-slack.sh",
    "dashboard": "node dashboard/server.js",
    "dashboard:dev": "nodemon dashboard/server.js",
    "manage-env": "node scripts/manage-env.js"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
